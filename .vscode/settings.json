{
    "latex-workshop.latex.autoBuild.onSave.files.ignore": ["**/template/*.tex"],
    "latex-workshop.latex.watch.files.ignore": ["**/template/*.tex"],
    "latex-workshop.latex.tools": [
        {
            "name": "lualatex",
            "command": "lualatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOCFILE%"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "lualatex",
            "tools": ["lualatex"]
        }
    ],
    "latex-workshop.latex.recipe.default": "lualatex"
}